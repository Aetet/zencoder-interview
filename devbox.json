{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "packages": [
    "nodejs@20",
    "pnpm@9",
    "rustup",
    "cmake",
    "pkg-config",
    "openssl",
    "rdkafka"
  ],
  "shell": {
    "init_hook": [
      "rustup default stable 2>/dev/null",
      "echo '✓ devbox shell ready — run: pnpm install'"
    ]
  }
}
